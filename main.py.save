"""
Main Application - Reception Robot
Coordinates all nodes and manages the system
"""

import sys
import os
import queue
import threading

# Add project root to path
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from nodes.gui_node import GUINode
from nodes.state_manager_node import StateManagerNode
from nodes.control_interface_node import ControlInterfaceNode
from nodes.sensor_node import SensorNode
from nodes.logger_node import LoggerNode
from nodes.sound_node import SoundNode
from config.config import ROBOT_CONFIG

class ReceptionRobotSystem:
    def __init__(self):
        """Initialize the Reception Robot System"""
        print("="*60)
        print("🤖 RECEPTION ROBOT SYSTEM STARTING")
        print("="*60)
        
        # Create communication queues
        self.state_queue = queue.Queue()
        self.emotion_queue = queue.Queue()
        self.command_queue = queue.Queue()
        self.log_queue = queue.Queue()
        
        # Initialize nodes
        print("\n[SYSTEM] Initializing nodes...")
        
        self.gui_node = GUINode(self.state_queue, self.emotion_queue)
        self.state_manager = StateManagerNode(
            self.state_queue,
            self.emotion_queue,
            self.command_queue
        )
        self.control_interface = ControlInterfaceNode(self.command_queue)
        self.sensor_node = SensorNode(self.command_queue)
        self.logger_node = LoggerNode(self.state_queue, 'logs/robot.log')
        
        print("[SYSTEM] All nodes initialized successfully!")
        print("="*60)
        
        # Start node threads
        self.threads = []
    
    def start(self):
        """Start all nodes"""
        print("\n[SYSTEM] Starting all nodes...\n")
        
        # Start state manager thread
        state_manager_thread = threading.Thread(
            target=self.state_manager.run,
            daemon=True
        )
        state_manager_thread.start()
        self.threads.append(state_manager_thread)
        
        # Start sensor node thread
        sensor_thread = threading.Thread(
            target=self.sensor_node.run,
            daemon=True
        )
        sensor_thread.start()
        self.threads.append(sensor_thread)
        
        # Start logger node thread
        logger_thread = threading.Thread(
            target=self.logger_node.run,
            daemon=True
        )
        logger_thread.start()
        self.threads.append(logger_thread)
        
        # Start control interface thread
        control_thread = threading.Thread(
            target=self.control_interface.run,
            daemon=True
        )
        control_thread.start()
        self.threads.append(control_thread)
        
        print("[SYSTEM] All background nodes started!")
        print("[SYSTEM] Starting GUI (main thread)...\n")
        print("="*60)
        print("✅ SYSTEM READY")
        print("="*60)
        print("\nControls:")
        print("  - Use the Control Interface window to change states")
        print("  - Watch the GUI window for robot emotions")
        print("  - Close any window to shutdown the system\n")
        
        # Start GUI (blocking call)
        try:
            self.gui_node.run()
        except KeyboardInterrupt:
            print("\n[SYSTEM] Keyboard interrupt received")
        finally:
            self.shutdown()
    
    def shutdown(self):
        """Shutdown all nodes"""
        print("\n[SYSTEM] Shutting down...")
        
        # Send shutdown command
        self.command_queue.put({'type': 'SHUTDOWN'})
        
        # Shutdown nodes
        self.gui_node.shutdown()
        self.control_interface.shutdown()
        self.sensor_node.shutdown()
        self.logger_node.shutdown()
        
        print("[SYSTEM] All nodes stopped")
        print("="*60)
        print("🤖 RECEPTION ROBOT SYSTEM STOPPED")
        print("="*60)


def main():
    """Main entry point"""
    try:
        system = ReceptionRobotSystem()
        system.start()
    except Exception as e:
        print(f"\n[SYSTEM] FATAL ERROR: {e}")
        import traceback
        traceback.print_exc()


if __name__ == "__main__":
    main()
